---
import Layout from '../../layouts/Layout.astro';
import courses from '../../data/courses.json';
import { courseSlug } from '../../lib/slugify';

export function getStaticPaths() {
  return courses.map((course) => ({
    params: { slug: courseSlug(course.curso, course.universidade) },
    props: { course },
  }));
}

const { course } = Astro.props;

const uniName = course.universidade.split(' - ')[0].trim();
const uniRest = course.universidade.includes(' - ')
  ? course.universidade.split(' - ').slice(1).join(' - ').trim()
  : null;

const notas = course.notas as Record<string, number>;
const years = Object.keys(notas).sort();
const latestYear = years[years.length - 1];
const latestNota = notas[latestYear];
const notaFormatted = (latestNota / 10).toFixed(1).replace('.', ',');

const prevYear = years.length >= 2 ? years[years.length - 2] : null;
const prevNota = prevYear ? notas[prevYear] : null;
const diff = prevNota ? ((latestNota - prevNota) / 10).toFixed(1) : null;

const allNotas = years.map((y) => notas[y] / 10);
const minNota = Math.min(...allNotas).toFixed(1).replace('.', ',');
const maxNota = Math.max(...allNotas).toFixed(1).replace('.', ',');

const pageTitle = `Médias de Entrada ${course.curso} — ${uniName} ${latestYear}`;
const pageDescription = `A nota mínima de entrada em ${course.curso} na ${uniName} em ${latestYear} foi ${notaFormatted} valores. Histórico completo de médias de ${years[0]} a ${latestYear}. ${course.vagas} vagas disponíveis.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOccupationalProgram',
  name: course.curso,
  provider: {
    '@type': 'CollegeOrUniversity',
    name: course.universidade,
  },
  educationalCredentialAwarded: course.grau,
  description: pageDescription,
  url: `https://medias.pt/curso/${courseSlug(course.curso, course.universidade)}`,
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <nav class="flex items-center justify-between px-6 md:px-12 py-4 md:py-5 border-b border-[#d4cdb8] sticky top-0 bg-white z-50">
    <a href="/" class="font-display text-3xl font-black tracking-tight flex items-center gap-2" style="font-family: 'Playfair Display', serif">
      <div class="w-2 h-2 rounded-full bg-[#1e3a5f]"></div>
      <div><em><span class="text-[#1e3a5f]">m</span>édias.pt</em></div>
    </a>
    <a href="/" class="text-sm text-[rgba(60,60,67,0.6)] hover:text-black transition-colors">← Todos os cursos</a>
  </nav>

  <main class="max-w-3xl mx-auto px-6 md:px-12 py-10 md:py-16">

    <!-- HEADER -->
    <div class="mb-10">
      <div class="font-mono text-[10px] tracking-widest text-[#1e3a5f] uppercase mb-3">
        <span class="font-bold">{uniName}</span>
        {uniRest && <span class="block font-normal mt-0.5">{uniRest}</span>}
      </div>
      <h1 class="font-display text-3xl md:text-4xl font-black leading-tight tracking-tighter mb-2">
        {course.curso}
      </h1>
      <p class="text-[rgba(60,60,67,0.6)] text-sm">{course.vagas} vagas · {course.grau}</p>
    </div>

    <!-- KEY STATS -->
    <div class="grid grid-cols-3 gap-px bg-[#d4cdb8] border border-[#d4cdb8] mb-10">
      <div class="bg-white p-5 md:p-6">
        <div class="text-xs text-[rgba(60,60,67,0.6)] mb-1">Nota {latestYear}</div>
        <div class="font-display text-4xl font-black text-[#1e3a5f]">{notaFormatted}</div>
        {diff !== null && (
          <div class={`font-mono text-xs mt-2 font-medium ${parseFloat(diff) > 0 ? 'text-[#b91c1c]' : parseFloat(diff) < 0 ? 'text-[#1a6b3c]' : 'text-[rgba(60,60,67,0.6)]'}`}>
            {parseFloat(diff) > 0 ? `↑ +${diff}` : parseFloat(diff) < 0 ? `↓ ${diff}` : '— 0,0'} vs {prevYear}
          </div>
        )}
      </div>
      <div class="bg-white p-5 md:p-6">
        <div class="text-xs text-[rgba(60,60,67,0.6)] mb-1">Mínimo histórico</div>
        <div class="font-display text-4xl font-black text-[#1a6b3c]">{minNota}</div>
        <div class="font-mono text-xs mt-2 text-[rgba(60,60,67,0.6)]">{years[0]}–{latestYear}</div>
      </div>
      <div class="bg-white p-5 md:p-6">
        <div class="text-xs text-[rgba(60,60,67,0.6)] mb-1">Máximo histórico</div>
        <div class="font-display text-4xl font-black text-[#b91c1c]">{maxNota}</div>
        <div class="font-mono text-xs mt-2 text-[rgba(60,60,67,0.6)]">{years[0]}–{latestYear}</div>
      </div>
    </div>

    <!-- GRADE HISTORY TABLE -->
    <div class="mb-10">
      <h2 class="font-mono text-[10px] tracking-widest text-[rgba(60,60,67,0.6)] uppercase mb-5">Histórico de notas de entrada</h2>
      <div class="border border-[#d4cdb8]">
        {years.slice().reverse().map((year, i) => {
          const nota = notas[year] / 10;
          const isLatest = i === 0;
          return (
            <div class={`flex items-center justify-between px-5 py-3 border-b border-[#d4cdb8] last:border-0 ${isLatest ? 'bg-white' : 'bg-white'}`}>
              <div class="flex items-center gap-3">
                <span class="font-mono text-sm font-medium">{year}</span>
                {isLatest && <span class="font-mono text-[9px] tracking-widest uppercase text-[#1e3a5f] border border-[#1e3a5f] px-1.5 py-0.5">Último</span>}
              </div>
              <div class="flex items-center gap-4">
                <div class="hidden sm:flex items-end gap-0.5 h-5">
                  <div
                    class="w-32 bg-[#d4cdb8] relative"
                    style="height: 100%"
                  >
                    <div
                      class="absolute left-0 top-0 h-full bg-[#1e3a5f] transition-all"
                      style={`width: ${Math.round(((nota - 10) / 10) * 100)}%`}
                    />
                  </div>
                </div>
                <span class="font-display text-lg font-bold w-12 text-right">{nota.toFixed(1).replace('.', ',')}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- PROBABILITY CALCULATOR -->
    <div class="bg-[#0e0e0e] text-[#f5f0e8] p-6 md:p-8 relative overflow-hidden mb-10">
<h2 class="font-display text-lg font-bold mb-2">Qual a tua probabilidade de entrada?</h2>
      <p class="text-sm text-white leading-relaxed mb-4">
        Insere a tua nota e calcula as tuas hipóteses com base no histórico dos últimos {years.length} anos.
      </p>
      <div class="flex flex-col sm:flex-row gap-2 mb-4">
        <input
          id="calcInput"
          type="text"
          inputmode="decimal"
          placeholder="Ex: 15,8"
          class="flex-1 px-4 py-2.5 bg-[#1a1a1a] border border-[#333] text-[#f5f0e8] outline-none focus:border-[#1e3a5f] transition-colors placeholder-white/50"
        />
        <button
          id="calcBtn"
          class="px-5 py-2.5 bg-[#1e3a5f] text-white text-sm font-semibold hover:bg-[#152a45] transition-colors"
        >Calcular →</button>
      </div>
      <div id="calcError" class="hidden text-xs text-[#e87070] mb-3">A nota deve estar entre 9,5 e 20 valores.</div>
      <div id="probResult" class="hidden">
        <div class="flex items-center gap-4">
          <div id="probPercent" class="font-display text-5xl font-black text-[#4a7fc1]"></div>
          <div>
            <div class="text-sm font-medium">probabilidade de entrada</div>
            <div id="probDetail" class="text-xs text-white mt-1"></div>
          </div>
        </div>
        <div class="mt-4 h-1.5 bg-[#333] overflow-hidden">
          <div id="probBarFill" class="h-full bg-[#1e3a5f] transition-all duration-500" style="width: 0%"></div>
        </div>
      </div>
    </div>

  </main>

  <footer class="border-t border-[#d4cdb8] px-6 md:px-12 py-6 flex justify-between items-center max-w-3xl mx-auto">
    <p class="text-xs text-[rgba(60,60,67,0.6)]">
      Dados: DGES — Direção-Geral do Ensino Superior · Atualizado em {latestYear} · Desenvolvido por Julião Silva
    </p>
    <a href="/" class="font-display text-base font-black">
      <span class="text-[#1e3a5f]">M</span>édias
    </a>
  </footer>

  <script define:vars={{ courseNotas: course.notas, courseYears: years }}>
    const calcInput = document.getElementById('calcInput');
    const calcBtn = document.getElementById('calcBtn');

    const errorMsg = document.getElementById('calcError');

    function calcProb() {
      const userGrade = parseFloat(calcInput.value.replace(',', '.'));
      if (isNaN(userGrade) || userGrade < 9.5 || userGrade > 20) {
        errorMsg.classList.remove('hidden');
        document.getElementById('probResult').classList.add('hidden');
        return;
      }
      errorMsg.classList.add('hidden');

      const sortedYears = courseYears.slice().sort();
      let totalWeight = 0;
      let weightedScore = 0;
      sortedYears.forEach((year, i) => {
        const weight = i + 1;
        totalWeight += weight;
        if (userGrade >= courseNotas[year] / 10) weightedScore += weight;
      });

      const prob = Math.round((weightedScore / totalWeight) * 100);
      const probResult = document.getElementById('probResult');
      probResult.classList.remove('hidden');
      document.getElementById('probPercent').textContent = `${prob}%`;
      document.getElementById('probDetail').textContent =
        `baseado em ${sortedYears.length} anos · anos recentes têm mais peso`;
      document.getElementById('probBarFill').style.width = `${prob}%`;
    }

    calcBtn.addEventListener('click', calcProb);
    calcInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') calcProb();
    });
  </script>
</Layout>
